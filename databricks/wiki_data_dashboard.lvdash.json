{
  "datasets": [
    {
      "name": "092e2e7b",
      "displayName": "Top 50 Most Edited Wiki Data",
      "queryLines": [
        "-- Retrieves the top 50 posts with the highest number of edits, showing their qid, name (label or qid), and edit count\r\n",
        "SELECT qid,\r\n",
        "       COALESCE(label, qid)      AS post_name,\r\n",
        "       COUNT(*)                  AS number_of_edits\r\n",
        "FROM workspace.default.wiki_data_enriched  \r\n",
        "GROUP  BY qid, label\r\n",
        "ORDER  BY number_of_edits DESC\r\n",
        "LIMIT  50;\r\n"
      ]
    },
    {
      "name": "0a184d12",
      "displayName": "bot or human",
      "queryLines": [
        "-- Counts the number of edits made by bots and humans, grouping by editor type\r\n",
        "SELECT IF(bot,'Bot','Human') AS editor_type,\r\n",
        "       COUNT(*)              AS edits\r\n",
        "FROM   workspace.default.wiki_data_enriched  \r\n",
        "GROUP  BY editor_type;"
      ]
    },
    {
      "name": "a6624354",
      "displayName": "instance_id",
      "queryLines": [
        "-- This query retrieves the top 50 Wikipedia instances by number of edits.\r\n",
        "-- It selects the instance QID, its label (or QID if label is missing), and the count of edits.\r\n",
        "-- Results are ordered by the number of edits in descending order.\r\n",
        "\r\n",
        "SELECT instance_qid,\r\n",
        "       COALESCE(instance_label, instance_qid)   AS post_name,\r\n",
        "       COUNT(*) AS number_of_edits\r\n",
        "FROM   workspace.default.wiki_data_enriched\r\n",
        "GROUP  BY instance_qid, instance_label\r\n",
        "ORDER  BY number_of_edits DESC\r\n",
        "LIMIT  50;"
      ]
    }
  ],
